# =============================================================================
# Yello Solar Hub - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# -----------------------------------------------------------------------------
# OpenAI Integration (Required)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-your-key-here

# ChatKit Configuration (Optional)
# Enable ChatKit embedded agent interface
VITE_OPENAI_CHATKIT_ENABLED=false
# Get workflow ID from: https://platform.openai.com/agent-builder
VITE_OPENAI_WORKFLOW_ID=wf_your-workflow-id-here

# OpenAI Features (Optional)
VITE_OPENAI_ASSISTANTS_ENABLED=false
VITE_OPENAI_WHISPER_ENABLED=false
VITE_OPENAI_REALTIME_ENABLED=false

# -----------------------------------------------------------------------------
# Maps & Geospatial (Optional)
# -----------------------------------------------------------------------------
# MapTiler API key for satellite imagery and terrain data
# Get key from: https://www.maptiler.com/cloud/
VITE_MAPTILER_API_KEY=demo

# Sentinel Hub for satellite data (Optional)
VITE_SENTINEL_HUB_INSTANCE_ID=
VITE_SENTINEL_HUB_CLIENT_ID=
VITE_SENTINEL_HUB_CLIENT_SECRET=

# NREL SAM API for solar calculations (Optional)
VITE_NREL_SAM_API_KEY=

# -----------------------------------------------------------------------------
# Authentication (Optional)
# -----------------------------------------------------------------------------
# Facebook OAuth
VITE_FACEBOOK_APP_ID=
# Auth service backend URL (if using external auth service)
VITE_AUTH_SERVICE_URL=

# GitHub OAuth (backend only - DO NOT expose to frontend)
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Payment Gateways (Backend Only - DO NOT expose to frontend)
# -----------------------------------------------------------------------------
VITE_ASAAS_TOKEN=
VITE_STRIPE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Analytics & Feature Flags (Optional)
# -----------------------------------------------------------------------------
VITE_CLARITY_TOKEN=
VITE_HYPERTUNE_TOKEN=
